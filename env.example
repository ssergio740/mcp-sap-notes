# ─── Authentication (choose one method) ─────────────────────────

# Option 1: Username/Password (optional; prompts can appear during authentication)
SAP_USERNAME=your.email@company.com
SAP_PASSWORD=your_sap_password

# Option 2: SAP Passport Certificate
# PFX_PATH=./certs/sap.pfx
# PFX_PASSPHRASE=your_certificate_passphrase_here

# Auth method selection: 'auto' (default), 'password', or 'certificate'
# auto = tries password first if credentials are set, then certificate
AUTH_METHOD=auto

# Encrypted SAP credential store used by the HTTP OAuth registration flow
# SAP_CRED_STORE_PATH=sap_credentials.json
# SAP_CRED_ENCRYPTION_KEY=your_fernet_key_here
# How long (seconds) SAP credentials are valid before the user must re-register (default: 86400 = 24h)
# SAP_CRED_TTL_SECONDS=86400

# ─── MFA / 2FA ──────────────────────────────────────────────────

# Timeout for manual 2FA code entry (ms). Set HEADFUL=true to see the prompt.
MFA_TIMEOUT=120000

# ─── General ────────────────────────────────────────────────────

# Token cache lifetime in hours (default: 12)
MAX_JWT_AGE_H=12

# Show browser window during authentication (required for manual 2FA)
HEADFUL=false

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─── HTTP FastMCP Server (optional) ────────────────────────────

# Public MCP URL used as the OAuth resource indicator.
MCP_SERVER_URL=https://your-public-host.example.com/mcp

# Microsoft Entra ID / Azure OAuth configuration.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
MCP_AUDIENCE=api://your-app-client-id
AZURE_REQUIRED_SCOPES=access_as_user

# HTTP port used by the FastMCP server.
HTTP_PORT=8090

# Optional path override for Python FastMCP HTTP mode.
MCP_HTTP_PATH=/mcp

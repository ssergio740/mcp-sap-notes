# ============================================
# Authentication (at least one method required)
# ============================================

# Option 1: Username/Password Authentication (recommended)
# More stable and works in automated/headless environments
SAP_USERNAME=your.email@company.com
SAP_PASSWORD=your_sap_password

# Option 2: Certificate Authentication
# Uses a .pfx client certificate for SAP IAS
# PFX_PATH=./certs/sap.pfx
# PFX_PASSPHRASE=your_certificate_passphrase

# Auth method selection: 'auto' (default), 'password', or 'certificate'
# auto = prefer password if credentials set, fall back to certificate
# AUTH_METHOD=auto

# MFA/2FA timeout in milliseconds (default: 120000 = 2 minutes)
# How long to wait for manual 2FA code entry in headful mode
# MFA_TIMEOUT=120000

# ============================================
# General Configuration (Optional)
# ============================================

# Maximum age of cached authentication in hours (default: 12)
MAX_JWT_AGE_H=12

# Set to 'true' to run browser in headful mode (required for MFA/2FA)
HEADFUL=false

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# HTTP Server Configuration (Optional)
# Only needed for Python FastMCP HTTP mode
# ============================================

# Public MCP URL used as the OAuth resource indicator
MCP_SERVER_URL=https://your-public-host.example.com/mcp

# Microsoft Entra ID / Azure OAuth
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
AZURE_REQUIRED_SCOPES=access_as_user

# Only users whose email domain matches one of these entries may access the server.
ALLOWED_EMAIL_DOMAINS=company.com,partner.com

# Optional path override for Python FastMCP HTTP mode
# MCP_HTTP_PATH=/mcp

# How long (seconds) SAP credentials are valid before the user must re-register (default: 86400 = 24h)
SAP_CRED_TTL_SECONDS=86400
